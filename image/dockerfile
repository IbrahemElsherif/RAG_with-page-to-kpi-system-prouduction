# 1. استخدام صورة بايثون 3.12 (نفس النسخة التي تعمل عليها)
FROM python:3.12-slim

# 2. إعداد المتغيرات البيئية لتحسين الأداء ومنع ملفات الكاش
ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1

# 3. تحديد مجلد العمل داخل الحاوية
WORKDIR /app

# 4. تثبيت مكتبات النظام الضرورية (مهم لـ ChromaDB و SQLite)
RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    gcc \
    && rm -rf /var/lib/apt/lists/*

# 5. نسخ ملف المتطلبات أولاً (للاستفادة من الكاش عند إعادة البناء)
COPY requirements.txt .

# 6. تثبيت المكتبات (سيتم تجاهل RAG_prouduction بفضل ملف .dockerignore)
RUN pip install --no-cache-dir --upgrade -r requirements.txt

# 7. نسخ باقي ملفات المشروع (الكود، القوالب، قاعدة البيانات)
COPY . .
WORKDIR /app/src/rag_app
# 8. فتح المنفذ 80
EXPOSE 80

# 9. أمر التشغيل
# نستخدم host 0.0.0.0 ليتمكن العالم الخارجي من رؤية الموقع
CMD ["uvicorn", "main:app", "--host", "0.0.0.0", "--port", "80"]